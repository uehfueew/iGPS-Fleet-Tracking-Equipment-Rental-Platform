generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int               @id @default(autoincrement())
  username       String            @unique
  password       String
  role           String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  subaccountId   Int?
  reportsCreated AutomatedReport[]
  companyProfile CompanyProfile?
  rentals        Rental[]
  subscription   Subscription?
  subaccount     Subaccount?       @relation(fields: [subaccountId], references: [id])
}

model CompanyProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  name            String
  logoUrl         String?
  locations       String?
  phoneNumber     String?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employeeCount   String?
  establishedYear Int?
  industry        String?
  taxId           String?
  website         String?
  user            User     @relation(fields: [userId], references: [id])
}

model Subaccount {
  id        Int      @id @default(autoincrement())
  name      String
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  groups    Group[]
  users     User[]
}

model Group {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  subaccountId Int?
  parentId     Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  parent       Group?      @relation("SubGroups", fields: [parentId], references: [id])
  subgroups    Group[]     @relation("SubGroups")
  subaccount   Subaccount? @relation(fields: [subaccountId], references: [id])
  vehicles     Vehicle[]
}

model Plan {
  id              Int            @id @default(autoincrement())
  name            String
  pricePerVehicle Float
  stripePriceId   String?
  subscriptions   Subscription[]
}

model Subscription {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  planId      Int
  status      String
  stripeSubId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plan        Plan     @relation(fields: [planId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Vehicle {
  id           Int         @id @default(autoincrement())
  name         String
  licensePlate String      @unique
  deviceId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  groupId      Int?
  alerts       Alert[]
  driverLogs   DriverLog[]
  fuelLogs     FuelLog[]
  positions    Position[]
  group        Group?      @relation(fields: [groupId], references: [id])
}

model Position {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  fuelLevel Float?
  timestamp DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Equipment {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  pricePerDay Float
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rentals     Rental[]
}

model Rental {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  clientId    Int
  startDate   DateTime
  endDate     DateTime
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      User      @relation(fields: [clientId], references: [id])
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
}

model Geofence {
  id        Int      @id @default(autoincrement())
  name      String
  polygon   Json
  vehicleId Int?
  createdAt DateTime @default(now())
}

model Alert {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  type      String
  message   String
  timestamp DateTime @default(now())
  isRead    Boolean  @default(false)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Driver {
  id            Int         @id @default(autoincrement())
  name          String
  licenseNumber String?
  contact       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  driverLogs    DriverLog[]
}

model DriverLog {
  id        Int      @id @default(autoincrement())
  driverId  Int
  vehicleId Int
  action    String
  notes     String?
  timestamp DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  amount    Float
  cost      Float?
  timestamp DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Route {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  startLocation Json?
  endLocation   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stops         Stop[]
}

model Stop {
  id           Int       @id @default(autoincrement())
  routeId      Int
  name         String
  location     Json
  assignedTime DateTime?
  route        Route     @relation(fields: [routeId], references: [id])
}

model AutomatedReport {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  schedule    String
  emailList   String
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [createdById], references: [id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}
