generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  password     String
  role         String // "admin" or "client"
  rentals      Rental[]
  subscription Subscription?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Plan {
  id              Int            @id @default(autoincrement())
  name            String
  pricePerVehicle Float
  stripePriceId   String?
  subscriptions   Subscription[]
}

model Subscription {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  planId      Int
  plan        Plan     @relation(fields: [planId], references: [id])
  status      String // "active", "past_due", "canceled"
  stripeSubId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vehicle {
  id           Int        @id @default(autoincrement())
  name         String
  licensePlate String     @unique
  deviceId     String? // optional, for GPS device
  positions    Position[]
  alerts       Alert[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Position {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  latitude  Float
  longitude Float
  speed     Float?
  timestamp DateTime @default(now())
  // TimescaleDB will handle this time‑series data, but we keep it in PostgreSQL for now
}

model Equipment {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  pricePerDay Float
  available   Boolean  @default(true)
  rentals     Rental[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Rental {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  clientId    Int
  client      User      @relation(fields: [clientId], references: [id])
  startDate   DateTime
  endDate     DateTime
  status      String // "pending", "approved", "declined", "active", "completed"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Geofence {
  id        Int      @id @default(autoincrement())
  name      String
  polygon   Json // store array of [lat, lng]
  vehicleId Int?
  createdAt DateTime @default(now())
}

model Alert {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  type      String // "geofence_enter", "geofence_exit"
  message   String
  timestamp DateTime @default(now())
  isRead    Boolean  @default(false)
}
