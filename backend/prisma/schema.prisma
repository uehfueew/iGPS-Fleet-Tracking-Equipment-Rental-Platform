generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int               @id @default(autoincrement())
  username       String            @unique
  password       String
  role           String
  subaccountId   Int?
  subaccount     Subaccount?       @relation(fields: [subaccountId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  rentals        Rental[]
  subscription   Subscription?
  reportsCreated AutomatedReport[]
}

model Subaccount {
  id        Int      @id @default(autoincrement())
  name      String
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  groups    Group[]
}

model Group {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  subaccountId Int?
  subaccount   Subaccount? @relation(fields: [subaccountId], references: [id])
  parentId     Int?
  parent       Group?      @relation("SubGroups", fields: [parentId], references: [id])
  subgroups    Group[]     @relation("SubGroups")
  vehicles     Vehicle[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Plan {
  id              Int            @id @default(autoincrement())
  name            String
  pricePerVehicle Float
  stripePriceId   String?
  subscriptions   Subscription[]
}

model Subscription {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  planId      Int
  status      String
  stripeSubId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plan        Plan     @relation(fields: [planId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Vehicle {
  id           Int         @id @default(autoincrement())
  name         String
  licensePlate String      @unique
  deviceId     String?
  groupId      Int?
  group        Group?      @relation(fields: [groupId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  alerts       Alert[]
  positions    Position[]
  driverLogs   DriverLog[]
  fuelLogs     FuelLog[]
}

model Position {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  fuelLevel Float?
  timestamp DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Equipment {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  pricePerDay Float
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rentals     Rental[]
}

model Rental {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  clientId    Int
  startDate   DateTime
  endDate     DateTime
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      User      @relation(fields: [clientId], references: [id])
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
}

model Geofence {
  id        Int      @id @default(autoincrement())
  name      String
  polygon   Json
  vehicleId Int?
  createdAt DateTime @default(now())
}

model Alert {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  type      String
  message   String
  timestamp DateTime @default(now())
  isRead    Boolean  @default(false)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Driver {
  id            Int         @id @default(autoincrement())
  name          String
  licenseNumber String?
  contact       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  driverLogs    DriverLog[]
}

model DriverLog {
  id        Int      @id @default(autoincrement())
  driverId  Int
  vehicleId Int
  action    String
  notes     String?
  timestamp DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  amount    Float
  cost      Float?
  timestamp DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Route {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  startLocation Json?
  endLocation   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stops         Stop[]
}

model Stop {
  id           Int       @id @default(autoincrement())
  routeId      Int
  name         String
  location     Json
  assignedTime DateTime?
  route        Route     @relation(fields: [routeId], references: [id])
}

model AutomatedReport {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  schedule    String
  emailList   String
  createdById Int
  creator     User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}
